# CareerOS — environment variable contract (example).
# Copy to `.env` and fill real values locally. NEVER commit `.env`.
# Only the variables needed by the current scaffold are listed; later stories
# (auth, DB, redis, AI) extend this file as they introduce configuration.

# ---- Runtime ----
# One of: development | test | staging | production
NODE_ENV=development
APP_ENV=development

# ---- Backend (apps/api) ----
# Bind host/port for the API.
API_HOST=0.0.0.0
API_PORT=8000
# Log level: debug | info | warning | error | critical
LOG_LEVEL=info
# Comma-separated list of allowed CORS origins (empty = none).
CORS_ORIGINS=http://localhost:3000

# ---- Frontend (apps/web) ----
# Base URL the web app uses to reach the API.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# ---- Database (S1-5) ----
# Async SQLAlchemy URL (asyncpg driver). Optional: the app boots without it and
# `/ready` reports the database unhealthy until it is set and reachable.
# DATABASE_URL=postgresql+asyncpg://careeros:careeros@localhost:5432/careeros

# ---- Cache / broker (introduced in S1-8) ----
# REDIS_URL=redis://localhost:6379/0
